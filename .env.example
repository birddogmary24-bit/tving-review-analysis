# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Batch update password (required for /api/[appId]/batch endpoint)
UPDATE_PASSWORD=your_secure_password_here

# Google Cloud Storage (production only)
GCS_BUCKET_NAME=your_bucket_name_here

# Gemini speed mode: 'true' for paid tier (2s delay), 'false' for free tier (6s delay)
GEMINI_FAST_MODE=false
